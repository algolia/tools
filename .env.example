# Server configuration
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# GCP Logging (required for server.js)
# Service account credentials for Cloud Logging
GCP_PROJECT_ID=alg-tools
GCP_CLIENT_EMAIL=alg-tools@alg-tools.iam.gserviceaccount.com
GCP_PRIVATE_KEY=<base64-encoded-private-key>

# Tool endpoints
TOOLS_ENDPOINT=http://localhost:8080
TOOLS_INTERNAL_ENDPOINT=http://127.0.0.1:8090

# Vue app env vars (also set in packages/*/.env.development)
VUE_APP_APP_ID=
VUE_APP_API_KEY=
VUE_APP_SEARCH_ONLY_API_KEY=
VUE_APP_METAPARAMS_BACKEND_ENDPOINT=
VUE_APP_PROXY_ENABLED=false
VUE_APP_TOOLS_INTERNAL_ENDPOINT=http://127.0.0.1:8090
