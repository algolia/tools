# Server configuration
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# GCP Logging (used by server.js)
# NOTE: This file is an example only; these variables must be provided via the process environment
# (e.g. export them in your shell, process manager, or use a dotenv loader if configured elsewhere).
# Service account credentials for Cloud Logging
GCP_PROJECT_ID=your-gcp-project-id
GCP_CLIENT_EMAIL=service-account@your-gcp-project.iam.gserviceaccount.com
GCP_PRIVATE_KEY=<base64-encoded-private-key>

# Tool endpoints
TOOLS_ENDPOINT=http://localhost:8080
TOOLS_INTERNAL_ENDPOINT=http://127.0.0.1:8090

# Vue app env vars (also set in packages/*/.env.development)
VUE_APP_APP_ID=
VUE_APP_API_KEY=
VUE_APP_SEARCH_ONLY_API_KEY=
VUE_APP_METAPARAMS_BACKEND_ENDPOINT=
VUE_APP_PROXY_ENABLED=false
VUE_APP_TOOLS_INTERNAL_ENDPOINT=http://127.0.0.1:8090
